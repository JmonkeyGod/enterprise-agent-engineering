---
import DocsLayout from '../layouts/DocsLayout.astro';
import Hero from '../components/Hero.astro';
import Principle from '../components/Principle.astro';
import Takeaway from '../components/Takeaway.astro';
const base = import.meta.env.BASE_URL;
const href = (value: string) => `${base}${value}`.replace(/\/+/g, '/');
---
<DocsLayout title="Home" description="Enterprise Agent Engineering, powered by EADL.">
  <Hero eyebrow="Enterprise Agent Engineering" title="Good agent systems are designed, not assembled." lede="EADL is a compact design language for building enterprise agents with clear boundaries, explicit state, observable actions, and human control." />
  <Principle title="Remove before add."><p>Every new agent, memory store, protocol, graph, or framework must explain the complexity it removes. If it cannot, it does not belong.</p></Principle>
  <section class="block"><h2>Explore the system</h2><div class="cards">
    <a class="card" href={href('concepts/')}><small>Stable ideas</small><h3>Concepts</h3><p>Decision, execution, state, memory, knowledge, tools, evaluation, and safety.</p></a>
    <a class="card" href={href('patterns/')}><small>Reusable structures</small><h3>Patterns</h3><p>Workflow + Agent, Human in the Loop, Router, Checkpoint, and controlled delegation.</p></a>
    <a class="card" href={href('recipes/')}><small>Technology-specific</small><h3>Recipes</h3><p>LangGraph, MCP, RAG, FastAPI, Docker, and observability implementations.</p></a>
    <a class="card" href={href('case-studies/')}><small>Enterprise context</small><h3>Case Studies</h3><p>The Enterprise Bid Agent and telecom B-domain intelligent operations.</p></a>
  </div></section>
  <Takeaway>Agent is decision. Workflow is execution. Database is truth. Memory is context.</Takeaway>
  <div class="footer-note">EADL v1.0 foundation · Stable concepts first. Technology remains replaceable.</div>
</DocsLayout>
